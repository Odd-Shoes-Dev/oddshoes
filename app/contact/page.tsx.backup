<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact — Odd Shoes</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>

<!-- ═══ NAVIGATION ═══ -->
<nav class="nav">
  <div class="nav__inner">
    <div class="nav__links nav__links--left">
      <a href="work.html" class="nav__link">Work</a>
      <a href="about.html" class="nav__link">About</a>
    </div>
    <a href="index.html" class="nav__logo">
      <div class="nav__logo-icon">O</div>
      <span class="nav__logo-text">Odd Shoes</span>
    </a>
    <div class="nav__links nav__links--right">
      <a href="give-him-50.html" class="nav__link">Give Him 50</a>
      <a href="contact.html" class="nav__link nav__link--active">Contact</a>
    </div>
    <button class="nav__hamburger" onclick="toggleMenu()">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- ═══ PAGE HERO ═══ -->
<section class="page-hero">
  <div class="container">
    <p class="label label--coral">Get in Touch</p>
    <h1>Let's build<br><em>something.</em></h1>
    <p>Whether you have a fully baked idea or a napkin sketch, we'd love to hear about it. No pressure, no pitch — just a conversation.</p>
  </div>
</section>

<!-- ═══ CONTACT GRID ═══ -->
<section class="section" style="padding-top:2rem;">
  <div class="container">
    <div class="contact-grid fade-up">

      <!-- LEFT: Info -->
      <div class="contact-info">
        <h2 style="margin-bottom:1.5rem;">How to reach us</h2>
        <p>We respond to every message within 24 hours. If it's urgent, WhatsApp is the fastest way to reach us.</p>

        <div class="contact-detail">
          <p class="label">Email</p>
          <a href="mailto:hello@oddshoes.co">hello@oddshoes.co</a>
        </div>

        <div class="contact-detail">
          <p class="label">WhatsApp</p>
          <a href="#">+256 700 000 000</a>
        </div>

        <div class="contact-detail">
          <p class="label">Office</p>
          <a href="#">Innovation Village, Ntinda<br>Kampala, Uganda</a>
        </div>

        <div class="contact-detail">
          <p class="label">Working Hours</p>
          <p style="font-size:1rem;color:var(--black);">Monday – Friday, 9am – 6pm EAT<br>
          <span style="font-size:.85rem;color:var(--gray-500);">We rest on Sundays. Worship first. ✝️</span></p>
        </div>

        <div style="display:flex;gap:1rem;margin-top:2rem;">
          <a href="#" class="btn btn--primary btn--small">💬 WhatsApp Us</a>
          <a href="#" class="btn btn--outline btn--small">📅 Book a Call</a>
        </div>
      </div>

      <!-- RIGHT: Form -->
      <div class="contact-form">
        <form id="contactForm">
          <div class="form-group">
            <label for="name">Your Name</label>
            <input type="text" id="name" placeholder="e.g. Sarah Namugwanya" required>
          </div>
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" placeholder="sarah@example.com" required>
          </div>
          <div class="form-group">
            <label for="service">What Do You Need?</label>
            <select id="service">
              <option value="">Select a service...</option>
              <option value="mvp">MVP Development</option>
              <option value="brand">Brand & Identity</option>
              <option value="uiux">UI/UX Design</option>
              <option value="web">Web Application</option>
              <option value="mobile">Mobile App</option>
              <option value="growth">Growth Strategy</option>
              <option value="other">Something Else</option>
            </select>
          </div>
          <div class="form-group">
            <label for="budget">Budget Range</label>
            <select id="budget">
              <option value="">Select your budget...</option>
              <option value="small">$2,000 – $5,000</option>
              <option value="medium">$5,000 – $15,000</option>
              <option value="large">$15,000 – $30,000</option>
              <option value="enterprise">$30,000+</option>
              <option value="unsure">Not sure yet</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Tell Us About Your Idea</label>
            <textarea id="message" placeholder="What's your vision? What problem does it solve? Who is it for? The more detail the better — but a few sentences is fine too." rows="5"></textarea>
          </div>
          <div class="form-group">
            <label for="referral">How Did You Find Us?</label>
            <select id="referral">
              <option value="">Select...</option>
              <option value="referral">Referral / Word of Mouth</option>
              <option value="social">Social Media</option>
              <option value="search">Google Search</option>
              <option value="church">Through a Church</option>
              <option value="other">Other</option>
            </select>
          </div>
          <button type="submit" class="btn btn--primary" style="width:100%;justify-content:center;margin-top:.5rem;">
            Launch It →
          </button>
          <p style="text-align:center;font-size:.8rem;color:var(--gray-400);margin-top:1rem;">We'll respond within 24 hours. No spam, ever.</p>
        </form>
      </div>

    </div>
  </div>
</section>

<!-- ═══ MAP ═══ -->
<section>
  <div class="map-embed fade-up" style="background:linear-gradient(135deg,#e8e4dd,#d4d4d4);position:relative;overflow:hidden;">
    <div style="text-align:center;z-index:1;position:relative;">
      <div style="font-size:2rem;margin-bottom:.5rem;">📍</div>
      <div style="font-family:var(--serif);font-size:1.3rem;color:var(--black);margin-bottom:.3rem;">Innovation Village, Ntinda</div>
      <div style="font-size:.85rem;color:var(--gray-500);">Kampala, Uganda</div>
    </div>
    <!-- Decorative grid lines -->
    <div style="position:absolute;inset:0;opacity:.08;">
      <div style="position:absolute;top:0;bottom:0;left:25%;width:1px;background:var(--black);"></div>
      <div style="position:absolute;top:0;bottom:0;left:50%;width:1px;background:var(--black);"></div>
      <div style="position:absolute;top:0;bottom:0;left:75%;width:1px;background:var(--black);"></div>
      <div style="position:absolute;left:0;right:0;top:33%;height:1px;background:var(--black);"></div>
      <div style="position:absolute;left:0;right:0;top:66%;height:1px;background:var(--black);"></div>
    </div>
  </div>
</section>

<!-- ═══ FAQ ═══ -->
<section class="section">
  <div class="container">
    <div class="section-header fade-up">
      <p class="label">FAQ</p>
      <h2>Common questions</h2>
    </div>
    <div style="max-width:700px;margin:0 auto;" class="fade-up">

      <div class="faq-item">
        <div class="faq-question" onclick="toggleFaq(this)">
          <span>How long does an MVP take to build?</span>
          <span class="faq-toggle">+</span>
        </div>
        <div class="faq-answer">
          <p>Typically 6–10 weeks from kickoff to launch. Our Strategy Sprint takes the first 2 weeks, then we build and ship in 4–8 weekly sprints depending on complexity.</p>
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question" onclick="toggleFaq(this)">
          <span>Do I need a technical co-founder?</span>
          <span class="faq-toggle">+</span>
        </div>
        <div class="faq-answer">
          <p>No! That's literally why we exist. You bring the vision and domain expertise — we handle the design, development, and technical architecture.</p>
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question" onclick="toggleFaq(this)">
          <span>Do I have to be a Christian to work with you?</span>
          <span class="faq-toggle">+</span>
        </div>
        <div class="faq-answer">
          <p>We welcome everyone! Our mission is rooted in Christian values, and we start sprints with prayer, but we serve founders of all backgrounds who share our values of integrity and generosity.</p>
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question" onclick="toggleFaq(this)">
          <span>What does "Give Him 50" mean for my project?</span>
          <span class="faq-toggle">+</span>
        </div>
        <div class="faq-answer">
          <p>It means when you hire us, 50% of our profit from your project goes directly to Kingdom work — missions, church planting, and community development. Your startup literally funds the Gospel.</p>
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question" onclick="toggleFaq(this)">
          <span>What's your tech stack?</span>
          <span class="faq-toggle">+</span>
        </div>
        <div class="faq-answer">
          <p>We're flexible, but our go-to stack is React/Next.js for web, React Native for mobile, Node.js or Python for backends, and PostgreSQL or Firebase for databases. We deploy on Vercel, AWS, or Google Cloud.</p>
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question" onclick="toggleFaq(this)">
          <span>Do you work with clients outside Uganda?</span>
          <span class="faq-toggle">+</span>
        </div>
        <div class="faq-answer">
          <p>Absolutely. We work with founders across East Africa, the US, UK, and beyond. We're fully remote-friendly with async workflows and weekly video check-ins.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
.faq-item {
  border-bottom: 1px solid var(--gray-200);
}
.faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 0;
  cursor: pointer;
  font-family: var(--serif);
  font-size: 1.1rem;
  color: var(--black);
  transition: color var(--transition);
}
.faq-question:hover { color: var(--coral); }
.faq-toggle {
  font-family: var(--sans);
  font-size: 1.5rem;
  font-weight: 300;
  color: var(--coral);
  transition: transform var(--transition);
  flex-shrink: 0;
  margin-left: 1rem;
}
.faq-item.open .faq-toggle { transform: rotate(45deg); }
.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height .4s ease, padding .4s ease;
  padding: 0;
}
.faq-item.open .faq-answer {
  max-height: 300px;
  padding-bottom: 1.5rem;
}
.faq-answer p {
  font-size: .95rem;
  line-height: 1.7;
}
</style>

<!-- ═══ SCRIPTURE ═══ -->
<section class="scripture">
  <div class="container fade-up">
    <p class="scripture__text">"Commit to the Lord whatever you do, and he will establish your plans."</p>
    <p class="scripture__ref">— Proverbs 16:3</p>
  </div>
</section>

<!-- ═══ FOOTER ═══ -->
<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <div style="display:flex;align-items:center;gap:.6rem;">
          <div class="nav__logo-icon">O</div>
          <span style="font-family:var(--serif);font-size:1.15rem;font-weight:600;">Odd Shoes</span>
        </div>
        <p>Building startups for Christian founders who want to honour God with their business. Based in Kampala, Uganda — serving the world.</p>
      </div>
      <div class="footer__col">
        <div class="footer__col-title">Navigate</div>
        <a href="index.html">Home</a>
        <a href="work.html">Work</a>
        <a href="about.html">About</a>
        <a href="give-him-50.html">Give Him 50</a>
      </div>
      <div class="footer__col">
        <div class="footer__col-title">Services</div>
        <a href="#">MVP Development</a>
        <a href="#">Brand & Identity</a>
        <a href="#">UI/UX Design</a>
        <a href="#">Growth Strategy</a>
      </div>
      <div class="footer__col">
        <div class="footer__col-title">Connect</div>
        <a href="#">hello@oddshoes.co</a>
        <a href="#">WhatsApp</a>
        <a href="#">Twitter / X</a>
        <a href="#">LinkedIn</a>
      </div>
    </div>
    <div class="footer__bottom">
      <p>© 2026 Odd Shoes. All rights reserved. · <a href="#" style="color:var(--gray-500);">Boring Legal Stuff</a></p>
      <div class="footer__socials">
        <a href="#">X</a>
        <a href="#">Li</a>
        <a href="#">Ig</a>
        <a href="#">Wa</a>
      </div>
    </div>
  </div>
</footer>

<script>
function toggleMenu() {
  document.querySelectorAll('.nav__links').forEach(el => el.classList.toggle('active'));
}
function toggleFaq(el) {
  const item = el.parentElement;
  item.classList.toggle('open');
}
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) entry.target.classList.add('visible');
  });
}, { threshold: 0.1 });
document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

// Form submit
document.getElementById('contactForm').addEventListener('submit', (e) => {
  e.preventDefault();
  const btn = e.target.querySelector('button[type="submit"]');
  btn.textContent = '✓ Message Sent!';
  btn.style.background = '#2d5a27';
  setTimeout(() => {
    btn.textContent = 'Launch It →';
    btn.style.background = '';
    e.target.reset();
  }, 3000);
});
</script>

</body>
</html>
